# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: The connection string for your remote PostgreSQL database.
# Configure this in the secrets manager if you wish to use remote PostgreSQL persistence.
# Example format: postgresql://username:password@hostname:5432/dbname
DATABASE_URL=

# JWT_SECRET: The secret key for signing secure JWT access tokens in production.
JWT_SECRET=

# JWT_REFRESH_SECRET: The secret key for signing secure JWT refresh tokens in production.
JWT_REFRESH_SECRET=

# ENABLE_DEV_AUTH_BYPASS: Set to "true" ONLY in local dev if you need to bypass authentication. Must be false or unset in production.
ENABLE_DEV_AUTH_BYPASS="false"

# NODE_ENV: Set to "production" in live deployment to enable strict checks and optimize the production build.
NODE_ENV="production"

# FRONTEND_ORIGIN: The origin domain of your frontend app for CORS configuration (if different from the backend URL).
FRONTEND_ORIGIN=

